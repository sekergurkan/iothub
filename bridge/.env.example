# The bridge is intentionally loopback-only by default.
HOST=127.0.0.1
PORT=8787

# Use * for a UI hosted on another origin, or a comma-separated allowlist.
CORS_ORIGINS=*

# Optional: avoids mDNS discovery during pairing and later restarts.
DIRIGERA_GATEWAY_IP=

# Keep certificate verification enabled. See README troubleshooting if needed.
DIRIGERA_REJECT_UNAUTHORIZED=true

EVENT_HISTORY_LIMIT=500

# Advanced options:
# BRIDGE_DATA_DIR=.data
# ALLOW_REMOTE_BIND=false
